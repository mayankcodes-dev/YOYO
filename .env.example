# ==============================================================================
# YOYO Hotel Booking — Server Environment Variables Template
# ==============================================================================
# Copy this file to .env and fill in the real values.
# NEVER commit the real .env file to version control.
# Add .env to .gitignore immediately.
#
# Usage:
#   cp .env.example .env
#   nano .env          # fill in every variable
# ==============================================================================

# ------------------------------------------------------------------------------
# APPLICATION
# ------------------------------------------------------------------------------

# The TCP port the Express server listens on.
# Must match the NGINX proxy_pass port (default: 4000).
PORT=4000

# Runtime environment. One of: development | test | production
NODE_ENV=production

# Public URL of the backend API (no trailing slash).
# Used for CORS allow-list, email links, and Swagger base URL.
API_BASE_URL=https://api.yoyo.mayankcodes.dev

# Public URL of the React frontend (no trailing slash).
# Used to set CORS allowed origin and build email action URLs.
CLIENT_URL=https://yoyo.mayankcodes.dev

# ------------------------------------------------------------------------------
# DATABASE — MongoDB Atlas
# ------------------------------------------------------------------------------

# Full MongoDB connection string from Atlas → Connect → Drivers.
# Format: mongodb+srv://<user>:<password>@<cluster>.mongodb.net/<dbname>?retryWrites=true&w=majority
# Replace <user>, <password>, <cluster>, and <dbname> with real values.
MONGODB_URI=mongodb+srv://yoyo_admin:REPLACE_WITH_REAL_PASSWORD@cluster0.abcde.mongodb.net/yoyo_production?retryWrites=true&w=majority

# Name of the MongoDB database (also embedded in the URI above, listed
# separately so seed scripts and migration tools can reference it easily).
DB_NAME=yoyo_production

# ------------------------------------------------------------------------------
# AUTHENTICATION — JWT
# ------------------------------------------------------------------------------

# Secret key used to sign JSON Web Tokens.
# Generate a strong random value:
#   node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
JWT_SECRET=REPLACE_WITH_64_BYTE_HEX_SECRET

# How long access tokens are valid.
# Uses the ms / jsonwebtoken duration format: 15m | 1h | 7d | 30d
JWT_EXPIRES_IN=7d

# Secret for refresh tokens (different from the access token secret).
# Generate separately:
#   node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
JWT_REFRESH_SECRET=REPLACE_WITH_ANOTHER_64_BYTE_HEX_SECRET

# How long refresh tokens are valid before the user must log in again.
JWT_REFRESH_EXPIRES_IN=30d

# ------------------------------------------------------------------------------
# EMAIL — Nodemailer / SMTP
# ------------------------------------------------------------------------------

# SMTP provider hostname.
# Examples: smtp.gmail.com | smtp.sendgrid.net | smtp.mailgun.org
SMTP_HOST=smtp.gmail.com

# SMTP port. Use 465 for SSL, 587 for STARTTLS.
SMTP_PORT=587

# Whether to use TLS directly (port 465 = true; port 587 = false, uses STARTTLS).
SMTP_SECURE=false

# SMTP authentication credentials.
# For Gmail: use an App Password, NOT your main account password.
# Generate at: https://myaccount.google.com/apppasswords
SMTP_USER=yoyo.noreply@gmail.com
SMTP_PASS=REPLACE_WITH_APP_PASSWORD

# The "From" address shown in outgoing emails.
EMAIL_FROM="YOYO Hotel Booking <yoyo.noreply@gmail.com>"

# ------------------------------------------------------------------------------
# PAYMENTS — Razorpay
# ------------------------------------------------------------------------------

# Razorpay API key ID (starts with "rzp_live_" in production, "rzp_test_" in dev).
# Dashboard → Settings → API Keys
RAZORPAY_KEY_ID=rzp_live_REPLACE_WITH_REAL_KEY_ID

# Razorpay API key secret (never expose this to the client).
RAZORPAY_KEY_SECRET=REPLACE_WITH_REAL_RAZORPAY_SECRET

# Razorpay Webhook Secret (generated when you create a webhook in the Dashboard).
# Used to verify that payment webhook events genuinely come from Razorpay.
RAZORPAY_WEBHOOK_SECRET=REPLACE_WITH_RAZORPAY_WEBHOOK_SECRET

# ------------------------------------------------------------------------------
# CLOUD STORAGE — AWS S3
# (Used for hotel images, room photos, and profile pictures)
# ------------------------------------------------------------------------------

# AWS IAM credentials for programmatic access.
# Create a dedicated IAM user with S3-only permissions; do NOT use root credentials.
AWS_ACCESS_KEY_ID=AKIAIOSFODNN7EXAMPLE
AWS_SECRET_ACCESS_KEY=wJalrXUtnFEMI/K7MDENG/bPxRfiCYEXAMPLEKEY

# The AWS region where your S3 bucket lives.
AWS_REGION=ap-south-1

# The name of the S3 bucket for uploaded assets.
AWS_S3_BUCKET=yoyo-hotel-assets-production

# Optional: CloudFront CDN distribution URL for serving S3 assets faster.
# Leave blank if you are serving files directly from S3.
AWS_CLOUDFRONT_URL=https://d1234567890abc.cloudfront.net

# ------------------------------------------------------------------------------
# SOCKET.IO / REAL-TIME
# ------------------------------------------------------------------------------

# Comma-separated list of origins allowed to open a WebSocket connection.
# Must exactly match the frontend origin (protocol + hostname + optional port).
SOCKET_ALLOWED_ORIGINS=https://yoyo.mayankcodes.dev

# How long (ms) the server waits before considering a connection timed out.
SOCKET_PING_TIMEOUT=10000

# How often (ms) the server pings connected clients.
SOCKET_PING_INTERVAL=25000

# ------------------------------------------------------------------------------
# RATE LIMITING
# ------------------------------------------------------------------------------

# Max number of requests per IP in the rate-limit window.
RATE_LIMIT_MAX=100

# Duration of the rate-limit window in minutes.
RATE_LIMIT_WINDOW_MINUTES=15

# Max login attempts before the account is temporarily locked out.
LOGIN_RATE_LIMIT_MAX=10

# Login rate-limit window in minutes.
LOGIN_RATE_LIMIT_WINDOW_MINUTES=15

# ------------------------------------------------------------------------------
# LOGGING
# ------------------------------------------------------------------------------

# Log level. One of: error | warn | info | http | verbose | debug | silly
LOG_LEVEL=info

# Log format. One of: combined | common | dev | short | tiny
# "combined" is standard Apache-style and recommended for production.
MORGAN_FORMAT=combined

# ------------------------------------------------------------------------------
# SESSION / COOKIE
# ------------------------------------------------------------------------------

# Secret used to sign session cookies (if you use express-session).
# Generate:  node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
SESSION_SECRET=REPLACE_WITH_32_BYTE_HEX_SESSION_SECRET

# Set to true in production to send cookies over HTTPS only.
COOKIE_SECURE=true

# Same-site cookie policy: strict | lax | none
# Use "lax" unless your frontend and backend share the same domain.
COOKIE_SAME_SITE=lax

# Cookie max-age in milliseconds (7 days = 604800000).
COOKIE_MAX_AGE=604800000

# ------------------------------------------------------------------------------
# ADMIN / SEED
# ------------------------------------------------------------------------------

# Credentials for the default admin account created by the database seed script.
# Change these IMMEDIATELY after first login.
ADMIN_EMAIL=admin@yoyo.mayankcodes.dev
ADMIN_PASSWORD=REPLACE_WITH_STRONG_ADMIN_PASSWORD

# ------------------------------------------------------------------------------
# EXTERNAL APIs (optional integrations)
# ------------------------------------------------------------------------------

# Google OAuth 2.0 (for "Sign in with Google")
# Credentials from: https://console.cloud.google.com/apis/credentials
GOOGLE_CLIENT_ID=REPLACE_WITH_GOOGLE_CLIENT_ID.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=REPLACE_WITH_GOOGLE_CLIENT_SECRET
GOOGLE_CALLBACK_URL=https://api.yoyo.mayankcodes.dev/auth/google/callback

# Mapbox (for hotel location maps in the frontend — exposed via the API
# to avoid embedding a public token directly in the React bundle).
MAPBOX_ACCESS_TOKEN=pk.eyJ1IjoibWF5YW5rIiwiYSI6ImN...REPLACE

# ------------------------------------------------------------------------------
# END OF FILE
# ------------------------------------------------------------------------------
